# Core paths
CGA_CHROMA_DIR=./chroma_db

# LLM defaults
CGA_MODEL_PROVIDER=ollama
CGA_DEFAULT_LLM_MODEL=deepseek-coder:1.3b
CGA_LLM_MAX_TOKENS=512
CGA_LLM_TEMPERATURE=0.0
CGA_LLM_TOP_P=1.0

# Retrieval
CGA_TOP_K=6

# Embeddings
CGA_EMBEDDING_MODEL=all-MiniLM-L6-v2
CGA_EMBEDDING_BATCH_SIZE=64
CGA_EMBEDDING_ENCODE_BATCH_SIZE=32

# Chunking
CGA_CHUNK_LINES=80
CGA_OVERLAP_LINES=20
CGA_MAX_FILE_SIZE_BYTES=2097152
